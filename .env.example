# ═══════════════════════════════════════════════════════════
# StreamForge v4.0 — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info

# Security
API_KEY=
RATE_LIMIT=30/minute

# Storage paths
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output

# Cloudflare R2 (optional — can also configure via UI)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Webhook (optional — POST notification on job complete)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Limits
MAX_UPLOAD_SIZE_GB=2
MAX_JOBS=100
JOB_TTL_HOURS=1
